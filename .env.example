# ============================================================
#  IBM Watsonx.ai + Multi-language Translator Agent — ENV
# ============================================================

# --- IBM Cloud credentials ---
IBM_API_KEY=your_api_key
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_PROJECT_ID=your_project_id

# --- Flask settings ---
FLASK_SECRET_KEY=change_this_to_a_random_secret_string
FLASK_ENV=development
FLASK_DEBUG=True

# --- Database ---
DATABASE_URL=sqlite:///instance/translator.db

# --- Upload settings ---
MAX_CONTENT_LENGTH_MB=25
UPLOAD_FOLDER=app/static/uploads

# --- RAG / Vector Store ---
VECTOR_STORE_PATH=app/data/vector_store
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Watsonx Model IDs ---
TRANSLATION_MODEL=ibm/granite-3-3-8b-instruct
SUMMARIZATION_MODEL=ibm/granite-3-3-8b-instruct
