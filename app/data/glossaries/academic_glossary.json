  "curriculum_frameworks": [
    {
      "id": "ncert_guidelines",
      "title": "NCERT Pedagogical Guidelines",
      "content": "NCERT recommends that translated educational material maintain the constructivist approach, encouraging critical thinking and inquiry-based learning. Technical terms should use approved regional language equivalents from NCERT glossaries. Mathematical content should preserve universal notation. Science diagrams labels remain bilingual."
    },
    {
      "id": "cbse_translation_policy",
      "title": "CBSE Language Policy",
      "content": "CBSE prescribes that translations of examination papers and textbooks follow the medium-specific terminology approved by regional language committees. Difficulty levels (easy, medium, hard) should be preserved through appropriate vocabulary choices. Question stems must maintain the same cognitive demand as the original."
    },
    {
      "id": "ugc_higher_ed",
      "title": "UGC Higher Education Translation Standards",
      "content": "UGC mandates that higher education content translated to regional languages maintain academic rigour. Citations and references remain in original script. Technical terminology may be transliterated where no regional equivalent exists. Research methodology terms follow international conventions."
    },
    {
      "id": "nep_2020_multilingual",
      "title": "NEP 2020 Multilingual Education Framework",
      "content": "National Education Policy 2020 emphasizes multilingual education with mother tongue instruction. Translations should bridge the gap between home language and academic language. Code-switching between languages is acceptable in explanatory footnotes. Cultural context should be preserved and enriched in translations."
    }
  ]
}
